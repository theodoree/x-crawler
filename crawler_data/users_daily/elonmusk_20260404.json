        "user": {
          "id": "2317231225",
          "name": "Yuri Bezmenov's Ghost",
          "screen_name": "Ne_pas_couvrir",
          "description": "The broad ideology of Marxism has killed roughly 100 million people. It's ghoulish and stupid. Classical liberalism actually works.",
          "followers_count": 60026,
          "friends_count": 658,
          "verified": false,
